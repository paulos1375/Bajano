{
  "version": 2,
  "redirects": [
    { "source": "/", "destination": "/nl", "permanent": false }
  ],
  "rewrites": [
    { "source": "/images/:path*", "destination": "/public/images/:path*" },
    { "source": "/css/:path*",    "destination": "/public/css/:path*" },
    { "source": "/js/:path*",     "destination": "/public/js/:path*" },
    { "source": "/plugin/:path*", "destination": "/public/plugin/:path*" },
    { "source": "/favicon.png",   "destination": "/public/favicon.png" },
    { "source": "/favicon.ico",   "destination": "/public/favicon.ico" },
    { "source": "/robots.txt",    "destination": "/public/robots.txt" },
    { "source": "/en",            "destination": "/views/index-en.html" },
    { "source": "/nl",            "destination": "/views/index-nl.html" },
    { "source": "/es",            "destination": "/views/index-es.html" },
    { "source": "/en/:page",      "destination": "/views/:page-en.html" },
    { "source": "/nl/:page",      "destination": "/views/:page-nl.html" },
    { "source": "/es/:page",      "destination": "/views/:page-es.html" }
  ]
}
